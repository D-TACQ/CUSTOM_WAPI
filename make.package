#!/bin/bash

DC=$(date +%y%m%d%H%M)
SEQ=80
PKG=custom_wapi
 
rm -Rf opkg/*
mkdir -p opkg/usr/local/WAPI
mkdir -p opkg/usr/local/init
mkdir -p release

cp -r WAPI/* opkg/usr/local/WAPI
cp init/* opkg/usr/local/init
cp README opkg/usr/local/init/${PKG}-README
rm -rf opkg/usr/local/WAPI/.vscode

tar cvzf release/${SEQ}-${PKG}-${DC}.tgz -C opkg .
ls -l release/${SEQ}-${PKG}-${DC}.tgz


#PACKAGES=../../PACKAGES
#rm -f ${PACKAGES}/${SEQ}-${PKG}*
#cp release/${SEQ}-${PKG}-${DC}.tgz ${PACKAGES}
