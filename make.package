#!/bin/bash

DC=$(date +%y%m%d%H%M)
SEQ=40
PKG=custom_wapi

rm -Rf opkg/*
mkdir -p opkg/usr/local/WAPI
mkdir -p opkg/usr/local/init
mkdir -p release

cp -r WAPI/* opkg/usr/local/WAPI
cp init/* opkg/usr/local/init

tar cvzf release/${SEQ}-${PKG}-${DC}.tgz -C opkg .
ls -l release/${SEQ}-${PKG}-${DC}.tgz


