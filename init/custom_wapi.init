#!/bin/sh

hapi_dir=/usr/local/HAPI
config=/mnt/local/sysconfig/endpoints.wapi
echo "[WAPI] Starting"

[ ! -e $hapi_dir ] && echo "[WAPI] Error: No HAPI" && exit 1
cd $hapi_dir
source ./setpath


[ ! -e $config ] && echo "[WAPI] Error: No config" && exit 1
source $config
echo "[WAPI] Loading ${ENDPOINTS}"

/usr/local/WAPI/wapi_server.py $ENDPOINTS &>/dev/null &